{
  "name": "doctor-clinic",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ./node_modules/next/dist/bin/next dev",
    "dev:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && node ./node_modules/next/dist/bin/next dev",
    "build": "node ./node_modules/prisma/build/index.js generate && node ./node_modules/next/dist/bin/next build",
    "start": "node ./node_modules/next/dist/bin/next start",
    "lint": "node ./node_modules/next/dist/bin/next lint",
    "clean": "node -e \"for (const p of ['.next','tsconfig.tsbuildinfo']) { try { require('fs').rmSync(p,{recursive:true,force:true}); } catch(e) {} }\"",
    "postinstall": "node ./node_modules/prisma/build/index.js generate",
    "db:generate": "node ./node_modules/prisma/build/index.js generate",
    "db:push": "node ./node_modules/prisma/build/index.js db push",
    "db:migrate": "node ./node_modules/prisma/build/index.js migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "node ./node_modules/prisma/build/index.js studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.468.0",
    "next": "15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.1",
    "postcss": "^8",
    "autoprefixer": "^10.5.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.1.0",
    "prisma": "^6.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
